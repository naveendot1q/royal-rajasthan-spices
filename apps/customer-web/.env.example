# ─── Supabase ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # SERVER ONLY — never expose

# ─── App URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
REVALIDATE_TOKEN=generate-a-random-32-char-string

# ─── Payments ───────────────────────────────────────────────────────
PAYMENT_PROVIDER=cod            # cod | razorpay | stripe

# Razorpay (only if PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# Stripe (only if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Search ─────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey_dev_royal_rajasthan

# ─── Cache (Upstash Redis) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=orders@royalrajasthanspices.com

# ─── SMS / WhatsApp (optional — app works without these) ────────────
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE=+91xxxxxxxxxx

# ─── Shipping ───────────────────────────────────────────────────────
SHIPPING_PROVIDER=manual        # manual | shiprocket | delhivery
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=xxx

# ─── Indian Tax ─────────────────────────────────────────────────────
GST_NUMBER=27XXXXX1234Z1
GST_RATE_PERCENT=5              # Spices = 5% GST (HSN 0910)

# ─── Monitoring ─────────────────────────────────────────────────────
GLITCHTIP_DSN=https://xxx@glitchtip.yourdomain.com/1
NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxx
NEXT_PUBLIC_UMAMI_URL=http://localhost:3010

# ─── Background Jobs (Trigger.dev) ──────────────────────────────────
TRIGGER_API_KEY=tr_dev_xxx
TRIGGER_API_URL=https://api.trigger.dev
